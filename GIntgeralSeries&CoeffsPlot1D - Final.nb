Cell[TextData[{
 "Then realize that: \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[PartialD]", "\[Lambda]"], 
         SubscriptBox[
          StyleBox["Z", "TI"], "\[Lambda]"], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["i", "TI"], "\[LongEqual]", "2", ",", 
            StyleBox["j", "TI"], "\[LongEqual]", "1"}], "\[Infinity]", 
          LimitsPositioning -> True], 
         FractionBox[
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"]}]], 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                StyleBox["i", "TI"], "-", "2"}], ")"}], "!", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["j", "TI"], "-", "1"}], ")"}], "!"}]], 
         SuperscriptBox["\[Lambda]", 
          RowBox[{
            StyleBox["i", "TI"], "-", "2"}]], 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], "-", "1"}]], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["i", "TI"], ",", 
            StyleBox["j", "TI"], "\[LongEqual]", "1"}], "\[Infinity]", 
          LimitsPositioning -> True], 
         FractionBox[
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{
             StyleBox["i", "TI"], "+", "1", ",", 
             StyleBox["j", "TI"]}]], 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["j", "TI"], "-", "1"}], ")"}], "!"}]], 
         SuperscriptBox["\[Lambda]", 
          RowBox[{
            StyleBox["i", "TI"], "-", "1"}]], 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\partial_\\lambda Z_\\lambda =\\sum_{i=2, j=1}^{\\infty} \
\\frac{c_{i,j}}{(i-2)!(j-1)!}\\lambda^{i-2}x^{j-1} = \\sum_{i,j=1}^{\\infty} \
\\frac{c_{i+1,j}}{(i-1)!(j-1)!}\\lambda^{i-1}x^{j-1}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "90899241-c996-9840-808b-552371841bf0"]
}], "Text",
 CellChangeTimes->{{3.9858632809379654`*^9, 3.9858632873823013`*^9}, {
