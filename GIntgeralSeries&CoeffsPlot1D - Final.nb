Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       RowBox[{"(", 
         RowBox[{
           FractionBox[
            SubscriptBox[
             StyleBox["c", "TI"], 
             RowBox[{
               SuperscriptBox[
                StyleBox["i", "TI"], "\[Prime]"], ",", 
               SuperscriptBox[
                StyleBox["j", "TI"], "\[Prime]"], "+", "1"}]], 
            RowBox[{
              RowBox[{"(", 
                RowBox[{
                  SuperscriptBox[
                   StyleBox["i", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
              RowBox[{"(", 
                RowBox[{
                  SuperscriptBox[
                   StyleBox["j", "TI"], "\[Prime]"], "-", "1"}], ")"}], 
              "!"}]], 
           SuperscriptBox["\[Lambda]", 
            RowBox[{
              SuperscriptBox[
               StyleBox["i", "TI"], "\[Prime]"], "-", "1"}]], 
           SuperscriptBox[
            StyleBox["x", "TI"], 
            RowBox[{
              SuperscriptBox[
               StyleBox["j", "TI"], "\[Prime]"], "-", "1"}]]}], ")"}], 
       RowBox[{"(", 
         RowBox[{
           FractionBox[
            SubscriptBox[
             StyleBox["c", "TI"], 
             RowBox[{
               OverscriptBox[
                StyleBox["i", "TI"], "~"], ",", 
               OverscriptBox[
                StyleBox["j", "TI"], "~"], "+", "1"}]], 
            RowBox[{
              RowBox[{"(", 
                RowBox[{
                  OverscriptBox[
                   StyleBox["i", "TI"], "~"], "-", "1"}], ")"}], "!", 
              RowBox[{"(", 
                RowBox[{
                  OverscriptBox[
                   StyleBox["j", "TI"], "~"], "-", "1"}], ")"}], "!"}]], 
           SuperscriptBox["\[Lambda]", 
            RowBox[{
              OverscriptBox[
               StyleBox["i", "TI"], "~"], "-", "1"}]], 
           SuperscriptBox[
            StyleBox["x", "TI"], 
            RowBox[{
              OverscriptBox[
               StyleBox["j", "TI"], "~"], "-", "1"}]]}], ")"}], 
       "\[LongEqual]", 
       FractionBox[
        RowBox[{
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{
             SuperscriptBox[
              StyleBox["i", "TI"], "\[Prime]"], ",", 
             SuperscriptBox[
              StyleBox["j", "TI"], "\[Prime]"], "+", "1"}]], 
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{
             OverscriptBox[
              StyleBox["i", "TI"], "~"], ",", 
             OverscriptBox[
              StyleBox["j", "TI"], "~"], "+", "1"}]]}], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["i", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              OverscriptBox[
               StyleBox["i", "TI"], "~"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["j", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              OverscriptBox[
               StyleBox["j", "TI"], "~"], "-", "1"}], ")"}], "!"}]], 
       SuperscriptBox["\[Lambda]", 
        RowBox[{
          SuperscriptBox[
           StyleBox["i", "TI"], "\[Prime]"], "-", "1", "+", 
          OverscriptBox[
           StyleBox["i", "TI"], "~"], "-", "1"}]], 
       SuperscriptBox[
        StyleBox["x", "TI"], 
        RowBox[{
          SuperscriptBox[
