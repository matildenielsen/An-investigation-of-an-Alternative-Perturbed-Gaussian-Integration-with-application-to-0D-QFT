          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], "-", "3"}], ")"}], "!"}]], 
       SuperscriptBox["\[Lambda]", 
        RowBox[{
          StyleBox["i", "TI"], "-", "1"}]], 
       SuperscriptBox[
        StyleBox["x", "TI"], 
        RowBox[{
          StyleBox["j", "TI"], "-", "3"}]], "\[LongEqual]", 
       UnderoverscriptBox["\[Sum]", 
        RowBox[{
          StyleBox["i", "TI"], ",", 
