Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       FractionBox[
        RowBox[{
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{
             SuperscriptBox[
              StyleBox["i", "TI"], "\[Prime]"], ",", 
             SuperscriptBox[
              StyleBox["j", "TI"], "\[Prime]"], "+", "1"}]], 
