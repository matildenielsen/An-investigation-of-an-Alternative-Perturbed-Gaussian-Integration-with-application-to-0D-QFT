     RowBox[{
       FractionBox[
        SubscriptBox[
         StyleBox["c", "TI"], 
         RowBox[{
           StyleBox["i", "TI"], "+", "1", ",", 
           StyleBox["j", "TI"]}]], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], "-", "1"}], ")"}], "!"}]], "\[LongEqual]", 
       FractionBox["1", 
        RowBox[{"2", 
          StyleBox["a", "TI"]}]], 
       RowBox[{"(", 
         RowBox[{
           FractionBox[
            SubscriptBox[
             StyleBox["c", "TI"], 
             RowBox[{
               StyleBox["i", "TI"], ",", 
               StyleBox["j", "TI"], "+", "2"}]], 
            RowBox[{
              RowBox[{"(", 
                RowBox[{
                  StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
              RowBox[{"(", 
                RowBox[{
                  StyleBox["j", "TI"], "-", "1"}], ")"}], "!"}]], "+", 
           UnderoverscriptBox["\[Sum]", 
            RowBox[{
              SuperscriptBox[
               StyleBox["i", "TI"], "\[Prime]"], ",", 
              SuperscriptBox[
               StyleBox["j", "TI"], "\[Prime]"], "\[LongEqual]", "1"}], 
            RowBox[{
