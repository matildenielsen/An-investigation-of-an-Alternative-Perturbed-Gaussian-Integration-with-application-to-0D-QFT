          StyleBox["j", "TI"], "-", "1"}]]}], TraditionalForm], 
   "errors" -> {}, "input" -> 
   "\\partial_x^2Z_\\lambda = \\sum_{i=1, j=2}^{\\infty} \
\\frac{c_{i,j}}{(i-1)!(j-3)!}\\lambda^{i-1}x^{j-3} = \\sum_{i,j=1}^{\\infty} \
\\frac{c_{i,j+2}}{(i-1)!(j-1)!}\\lambda^{i-1}x^{j-1}", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
