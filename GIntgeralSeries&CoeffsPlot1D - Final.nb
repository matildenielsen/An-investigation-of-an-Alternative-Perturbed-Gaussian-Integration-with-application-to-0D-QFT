         SuperscriptBox[
          StyleBox["j", "TI"], "\[Prime]"], "+", 
         OverscriptBox[
          StyleBox["j", "TI"], "~"], "-", "1", ","}], TraditionalForm], 
     "errors" -> {}, "input" -> "i= i' + \\tilde{i}-1, j= j' + \\tilde{j}-1,",
      "state" -> "Boxes"|>,
