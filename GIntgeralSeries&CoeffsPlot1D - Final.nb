Cell[BoxData[
 RowBox[{
  RowBox[{"ObtGIntSimpel", "[", 
   RowBox[{"v_", ",", " ", "a_"}], "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "C", ",", " ", "dim", " ", ",", "rows", ",", "cols", ",", " ", "Z"}], 
     "}"}], ",", " ", 
    RowBox[{
     RowBox[{"C", "=", " ", 
      RowBox[{"CoeffSeriesPerGaus", "[", 
       RowBox[{"v", ",", " ", "a"}], "]"}]}], ";", " ", 
     RowBox[{"dim", " ", "=", " ", 
      RowBox[{"Dimensions", "[", "C", "]"}]}], ";", " ", 
     RowBox[{"rows", "=", " ", 
      RowBox[{"dim", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", 
     RowBox[{"cols", "=", 
      RowBox[{"dim", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Z", "=", " ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"i", "-", "1"}], ")"}], "!"}], " ", "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "-", "1"}], ")"}], "!"}]}], ")"}]}], "*", " ", 
         RowBox[{"C", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "j"}], "]"}], "]"}], " ", "*", " ", 
         RowBox[{"\[Lambda]", "^", 
          RowBox[{"(", 
           RowBox[{"i", "-", "1"}], ")"}]}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{"j", "-", "1"}], ")"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "rows"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "cols"}], "}"}]}], "]"}]}], ";", "  ", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"2", "*", "Pi"}], "]"}], "*", 
      RowBox[{"a", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "/", "2"}], ")"}]}], "*", 
      RowBox[{"\[DoubleStruckCapitalE]", "[", 
       RowBox[{"Collect", "[", 
        RowBox[{
         RowBox[{"FullSimplify", "[", 
          RowBox[{
           RowBox[{"Z", "/.", 
            RowBox[{"\[Lambda]", "\[Rule]", "1"}]}], "/.", 
           RowBox[{"Thread", "[", 
            RowBox[{"x", "\[Rule]", "0"}], "]"}]}], "]"}], ",", 
         "\[Epsilon]"}], "]"}], "]"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.993308549124485*^9, 3.993308562711672*^9}, {
  3.993309008033201*^9, 3.9933090199591293`*^9}, {3.993309516320709*^9, 
  3.9933095170562153`*^9}, {3.9933100812087116`*^9, 3.993310089812748*^9}, {
