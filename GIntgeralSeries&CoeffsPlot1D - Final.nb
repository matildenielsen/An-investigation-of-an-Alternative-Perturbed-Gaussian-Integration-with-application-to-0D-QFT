              StyleBox["j", "TI"]}], LimitsPositioning -> True], 
           FractionBox[
            RowBox[{
              SubscriptBox[
               StyleBox["c", "TI"], 
               RowBox[{
                 SuperscriptBox[
                  StyleBox["i", "TI"], "\[Prime]"], ",", 
                 SuperscriptBox[
                  StyleBox["j", "TI"], "\[Prime]"], "+", "1"}]], 
              SubscriptBox[
               StyleBox["c", "TI"], 
               RowBox[{
                 StyleBox["i", "TI"], "-", 
                 SuperscriptBox[
                  StyleBox["i", "TI"], "\[Prime]"], "+", "1", ",", 
                 StyleBox["j", "TI"], "-", 
                 SuperscriptBox[
                  StyleBox["j", "TI"], "\[Prime]"], "+", "2"}]]}], 
            RowBox[{
              RowBox[{"(", 
                RowBox[{
                  SuperscriptBox[
                   StyleBox["i", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
              RowBox[{"(", 
                RowBox[{
                  StyleBox["i", "TI"], "-", 
                  SuperscriptBox[
                   StyleBox["i", "TI"], "\[Prime]"]}], ")"}], "!", 
              RowBox[{"(", 
                RowBox[{
                  SuperscriptBox[
                   StyleBox["j", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
              RowBox[{"(", 
                RowBox[{
                  StyleBox["j", "TI"], "-", 
                  SuperscriptBox[
                   StyleBox["j", "TI"], "\[Prime]"]}], ")"}], "!"}]]}], 
         ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
   "\\frac{c_{i+1,j}}{(i-1)!(j-1)!} = \
\\frac{1}{2a}(\\frac{c_{i,j+2}}{(i-1)!(j-1)!} + \\sum_{i', \
j'=1}^{i,j}\\frac{c_{i',j'+1}c_{i-i'+1,j-j'+2}}{(i'-1)!(i-i')!(j'-1)!(j-j')!})\
", "state" -> "Boxes"|>,
