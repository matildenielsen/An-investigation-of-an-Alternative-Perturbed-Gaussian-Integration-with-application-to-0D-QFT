             StyleBox["j", "TI"], "-", 
             SuperscriptBox[
              StyleBox["j", "TI"], "\[Prime]"], "+", "1", "+", "1"}]]}], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["i", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], "-", 
              SuperscriptBox[
               StyleBox["i", "TI"], "\[Prime]"], "+", "1", "-", "1"}], ")"}], 
          "!", 
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["j", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], "-", 
              SuperscriptBox[
               StyleBox["j", "TI"], "\[Prime]"], "+", "1", "-", "1"}], ")"}], 
          "!"}]], 
       SuperscriptBox["\[Lambda]", 
        RowBox[{
          StyleBox["i", "TI"], "-", "1"}]], 
       SuperscriptBox[
        StyleBox["x", "TI"], 
        RowBox[{
          StyleBox["j", "TI"], "-", "1"}]], "\[LongEqual]", 
       FractionBox[
        RowBox[{
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{
             SuperscriptBox[
              StyleBox["i", "TI"], "\[Prime]"], ",", 
             SuperscriptBox[
              StyleBox["j", "TI"], "\[Prime]"], "+", "1"}]], 
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{
             StyleBox["i", "TI"], "-", 
             SuperscriptBox[
              StyleBox["i", "TI"], "\[Prime]"], "+", "1", ",", 
             StyleBox["j", "TI"], "-", 
             SuperscriptBox[
              StyleBox["j", "TI"], "\[Prime]"], "+", "2"}]]}], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["i", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], "-", 
              SuperscriptBox[
               StyleBox["i", "TI"], "\[Prime]"]}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["j", "TI"], "\[Prime]"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], "-", 
              SuperscriptBox[
               StyleBox["j", "TI"], "\[Prime]"]}], ")"}], "!"}]], 
       SuperscriptBox["\[Lambda]", 
        RowBox[{
          StyleBox["i", "TI"], "-", "1"}]], 
       SuperscriptBox[
        StyleBox["x", "TI"], 
        RowBox[{
          StyleBox["j", "TI"], "-", "1"}]]}], TraditionalForm], 
   "errors" -> {}, "input" -> 
   "\\frac{c_{i',j'+1}c_{i-i'+1,j-j'+1+1}}{(i'-1)!(i-i'+1-1)!(j'-1)!(j-j'+1-1)\
!}\\lambda^{i-1}x^{j-1} = \
\\frac{c_{i',j'+1}c_{i-i'+1,j-j'+2}}{(i'-1)!(i-i')!(j'-1)!(j-j')!}\\lambda^{i-\
1}x^{j-1}", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
