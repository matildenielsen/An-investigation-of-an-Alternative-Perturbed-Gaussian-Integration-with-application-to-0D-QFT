        LimitsPositioning -> True], 
       FractionBox[
        SubscriptBox[
         StyleBox["c", "TI"], 
         RowBox[{
           StyleBox["i", "TI"], ",", 
           StyleBox["j", "TI"], "+", "2"}]], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
