Cell[TextData[{
 "Again off by sqrt{2\\pi}\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SuperscriptBox["\[Epsilon]", "0"], ",", 
          SuperscriptBox[
           StyleBox["J", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\epsilon^0, J^2", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "term", " ", "equals", "  ", 
    RowBox[{"1", "/", "2"}], 
    RowBox[{"m", "^", "2"}], " ", "as", " ", "expected"}], TraditionalForm]],
  ExpressionUUID->"9c390245-be36-2144-825d-2822783ef6c7"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Epsilon]", "1"], ",", 
         SuperscriptBox[
          StyleBox["J", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\epsilon^1, J^0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5cd2e881-8a79-f947-b456-b117b43798d7"],
 " term equals -1/8m^4 as expected\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Epsilon]", "1"], ",", 
         SuperscriptBox[
          StyleBox["J", "TI"], "4"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\epsilon^1, J^4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c66b5f4-c210-3249-8399-751685147d41"],
 " term equals -1/24m^8 not -35/192m^8 which is what it should be \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Epsilon]", "2"], ",", 
         SuperscriptBox[
          StyleBox["J", "TI"], "4"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\epsilon^2, J^4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7dfbaa09-7ddf-2f4b-be94-9bf5afb9327b"],
 " term equals 7/48m^12 not 385/1024 m^12 which is what it should be\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Epsilon]", "2"], ",", 
         SuperscriptBox[
          StyleBox["J", "TI"], "6"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\epsilon^2, J^6", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5d02b640-0b3f-ff4d-a0f3-909d791d0503"],
 " term equals 1/72m^14 not 1001/6144 m^14 which is what it should be"
}], "Text",
 CellChangeTimes->{{3.987576882857258*^9, 3.9875770040206223`*^9}, {
  3.9875770343823776`*^9, 3.9875771041670456`*^9}, {3.9875772269822693`*^9, 
  3.987577268986618*^9}, {3.9875773374420795`*^9, 3.987577382617546*^9}, {
  3.987577489673666*^9, 3.987577548593685*^9}, {3.987577616608103*^9, 
  3.987577686941246*^9}, {3.9875778125864754`*^9, 3.9875778566770306`*^9}, {
  3.987577910939499*^9, 3.9875779227045135`*^9}, {3.9875779688288136`*^9, 
  3.9875779707182407`*^9}, {3.9875780408753033`*^9, 
  3.987578056712969*^9}},ExpressionUUID->"315e5b5b-166f-bc47-a26d-\
8f520d5cb54c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ObtZSimpel", "[", 
   RowBox[{"v_", ",", " ", "a_"}], "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "C", ",", " ", "dim", " ", ",", "rows", ",", "cols", ",", " ", "Z"}], 
     "}"}], ",", " ", 
    RowBox[{
     RowBox[{"C", "=", " ", 
      RowBox[{"CoeffSeriesPerGaus", "[", 
       RowBox[{"v", ",", " ", "a"}], "]"}]}], ";", " ", 
     RowBox[{"dim", " ", "=", " ", 
      RowBox[{"Dimensions", "[", "C", "]"}]}], ";", " ", 
     RowBox[{"rows", "=", " ", 
      RowBox[{"dim", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", 
     RowBox[{"cols", "=", 
      RowBox[{"dim", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Z", "=", " ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"i", "-", "1"}], ")"}], "!"}], " ", "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "-", "1"}], ")"}], "!"}]}], ")"}]}], "*", " ", 
         RowBox[{"C", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "j"}], "]"}], "]"}], " ", "*", " ", 
         RowBox[{"\[Lambda]", "^", 
          RowBox[{"(", 
           RowBox[{"i", "-", "1"}], ")"}]}], "*", 
         RowBox[{"x", "^", 
          RowBox[{"(", 
           RowBox[{"j", "-", "1"}], ")"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "rows"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "cols"}], "}"}]}], "]"}]}], ";", "  ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"Z", "/.", 
        RowBox[{"\[Lambda]", "\[Rule]", "1"}]}], "/.", 
       RowBox[{"Thread", "[", 
        RowBox[{"x", "\[Rule]", "0"}], "]"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"6979cb7b-5155-8f46-82f4-34f59d52c166"],

