Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Plotcoeffs", "[", "C_", "]"}], ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"dim", " ", ",", "rows", ",", "cols"}], "}"}], ",", 
     RowBox[{
      RowBox[{"dim", " ", "=", " ", 
       RowBox[{"Dimensions", "[", "C", "]"}]}], ";", " ", 
      RowBox[{"rows", "=", " ", 
       RowBox[{"dim", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", 
      RowBox[{"cols", "=", 
       RowBox[{"dim", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Graphic", "=", " ", 
       RowBox[{"Graphics", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"C", "[", 
                 RowBox[{"[", 
                  RowBox[{"x", ",", "y"}], "]"}], "]"}], "==", "0"}], ",", 
               "Black", ",", "White"}], "]"}], ",", 
             RowBox[{"Rectangle", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"x", "-", "1.5"}], ",", 
                 RowBox[{"y", "-", "1.5"}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"x", "-", "0.5"}], ",", 
                 RowBox[{"y", "-", "0.5"}]}], "}"}]}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "1", ",", "rows"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"y", ",", "1", ",", "cols"}], "}"}]}], "]"}], ",", 
         RowBox[{"Axes", "->", "False"}], ",", 
         RowBox[{"Frame", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
