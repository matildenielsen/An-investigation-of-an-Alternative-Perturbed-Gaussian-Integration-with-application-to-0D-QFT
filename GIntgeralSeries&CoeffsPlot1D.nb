Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       SubscriptBox["\[PartialD]", 
        StyleBox["x", "TI"]], 
       SubscriptBox[
        StyleBox["Z", "TI"], "\[Lambda]"], "\[LongEqual]", 
       UnderoverscriptBox["\[Sum]", 
        RowBox[{
          StyleBox["i", "TI"], "\[LongEqual]", "1", ",", 
          StyleBox["j", "TI"], "\[LongEqual]", "2"}], "\[Infinity]", 
        LimitsPositioning -> True], 
       FractionBox[
        SubscriptBox[
         StyleBox["c", "TI"], 
         RowBox[{
           StyleBox["i", "TI"], ",", 
           StyleBox["j", "TI"]}]], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], "-", "2"}], ")"}], "!"}]], 
       SuperscriptBox["\[Lambda]", 
        RowBox[{
          StyleBox["i", "TI"], "-", "1"}]], 
       SuperscriptBox[
        StyleBox["x", "TI"], 
        RowBox[{
          StyleBox["j", "TI"], "-", "2"}]], "\[LongEqual]", 
       UnderoverscriptBox["\[Sum]", 
        RowBox[{
          StyleBox["i", "TI"], ",", 
          StyleBox["j", "TI"], "\[LongEqual]", "1"}], "\[Infinity]", 
        LimitsPositioning -> True], 
       FractionBox[
        SubscriptBox[
         StyleBox["c", "TI"], 
         RowBox[{
           StyleBox["i", "TI"], ",", 
           StyleBox["j", "TI"], "+", "1"}]], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], "-", "1"}], ")"}], "!"}]], 
       SuperscriptBox["\[Lambda]", 
        RowBox[{
          StyleBox["i", "TI"], "-", "1"}]], 
       SuperscriptBox[
        StyleBox["x", "TI"], 
        RowBox[{
          StyleBox["j", "TI"], "-", "1"}]]}], TraditionalForm], 
   "errors" -> {}, "input" -> 
   "$\\partial_x Z_\\lambda =\\sum_{i=1, j=2}^{\\infty} \
\\frac{c_{i,j}}{(i-1)!(j-2)!}\\lambda^{i-1}x^{j-2} = \\sum_{i,j=1}^{\\infty} \
\\frac{c_{i,j+1}}{(i-1)!(j-1)!}\\lambda^{i-1}x^{j-1}$", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{
  3.9871269299344673`*^9},ExpressionUUID->"af10caeb-647d-0a4f-853d-\
6308672280f2"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       SubsuperscriptBox["\[PartialD]", 
        StyleBox["x", "TI"], "2"], 
       SubscriptBox[
        StyleBox["Z", "TI"], "\[Lambda]"], "\[LongEqual]", 
       UnderoverscriptBox["\[Sum]", 
        RowBox[{
          StyleBox["i", "TI"], "\[LongEqual]", "1", ",", 
          StyleBox["j", "TI"], "\[LongEqual]", "2"}], "\[Infinity]", 
        LimitsPositioning -> True], 
