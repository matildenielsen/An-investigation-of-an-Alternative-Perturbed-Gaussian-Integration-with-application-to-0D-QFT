          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], "-", "3"}], ")"}], "!"}]], 
       SuperscriptBox["\[Lambda]", 
        RowBox[{
