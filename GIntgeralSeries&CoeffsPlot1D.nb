Notebook[{
Cell[TextData[{
 "Here below we will derive the similar coefficient relation but now for the \
case that the series is: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["Z", "TI"], "\[Lambda]"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["i", "TI"], ",", 
            StyleBox["j", "TI"], "\[LongEqual]", "1"}], "\[Infinity]", 
          LimitsPositioning -> True], 
         FractionBox[
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"]}]], 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                StyleBox["i", "TI"], "-", "1"}], ")"}], "!", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["j", "TI"], "-", "1"}], ")"}], "!"}]], 
         SuperscriptBox["\[Lambda]", 
          RowBox[{
            StyleBox["i", "TI"], "-", "1"}]], 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "Z_\\lambda(x) = \\sum_{i, j=1}^\\infty \
\\frac{c_{i,j}}{(i-1)!(j-1)!}\\lambda^{i-1}x^{j-1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5b8ee5f1-9d3c-a844-96a1-1fd628fc339d"]
}], "Text",
 CellChangeTimes->{{3.9858632809379654`*^9, 3.9858632873823013`*^9}, {
   3.9858633818818493`*^9, 3.985863410212538*^9}, {3.985863462351101*^9, 
   3.985863479721012*^9}, {3.985863529437292*^9, 3.9858635406221943`*^9}, {
   3.9858636407211246`*^9, 3.985863665992029*^9}, {3.9858664722509174`*^9, 
   3.985866514306671*^9}, {3.985866578339798*^9, 3.9858665867263546`*^9}, 
   3.9858667171963196`*^9, {3.985868154800953*^9, 3.9858681880689735`*^9}, {
   3.985868298697218*^9, 3.985868305846407*^9}, {3.985868455648964*^9, 
   3.9858684581947975`*^9}, 3.9858685613822956`*^9, {3.985868603372431*^9, 
   3.9858686256403465`*^9}, {3.9858688530321407`*^9, 3.98586887956147*^9}, {
   3.985868916052578*^9, 3.985868930610161*^9}, {3.9858691810039463`*^9, 
   3.985869222547373*^9}, {3.9858692663148212`*^9, 3.9858692696527386`*^9}, {
   3.985869403636631*^9, 3.9858694102273903`*^9}, {3.9858698308549366`*^9, 
   3.985869834312622*^9}, {3.9863480298695335`*^9, 3.9863480630956173`*^9}, {
   3.9867849056395454`*^9, 3.9867849210469227`*^9}, 3.986785022897545*^9, {
   3.986785148547104*^9, 3.986785178138281*^9}, {3.9867866108673267`*^9, 
   3.9867866124014854`*^9}, {3.9867872993355064`*^9, 3.986787299829012*^9}, 
   3.9871269110848274`*^9, 
   3.9904257832006474`*^9},ExpressionUUID->"35f7047d-bd2a-dc41-bceb-\
b1233318d697"],

Cell[TextData[{
 "This in turn means that the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["V", "TI"], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "V(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2caa737e-ee1c-8a49-82c8-a8c956f7be9b"],
 " will equal to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"log", 
         RowBox[{"(", 
           SqrtBox[
            RowBox[{"2", "\[Pi]"}]], ")"}], 
         StyleBox["V", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["Z", "TI"], "0"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["i", "TI"], "\[LongEqual]", "1"}], "\[Infinity]", 
          LimitsPositioning -> True], 
         FractionBox[
          SubscriptBox[
           StyleBox["c", "TI"], 
           RowBox[{"0", ",", 
             StyleBox["j", "TI"]}]], 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                StyleBox["j", "TI"], "-", "1"}], ")"}], "!"}]], 
         SuperscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\log(\\sqrt{2 \\pi})V(x) = Z_0(x) = \\sum_{i=1}^\\infty \
\\frac{c_{0,j}}{(j-1)!}x^{j-1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6a62b24e-10e6-0044-851f-c25d9dfedad1"]
}], "Text",
 CellChangeTimes->{{3.9858632809379654`*^9, 3.9858632873823013`*^9}, {
   3.9858633818818493`*^9, 3.985863410212538*^9}, {3.985863462351101*^9, 
   3.985863479721012*^9}, {3.985863529437292*^9, 3.9858635406221943`*^9}, {
