Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Should", " ", "be", " ", "with", " ", "corrected", " ", "indices"}], ",", 
    RowBox[{
    "considering", " ", "the", " ", "sum", " ", "starts", " ", "from", " ", 
     RowBox[{"one", ":"}]}]}], "*)"}], 
  RowBox[{
   RowBox[{"CoeffSeriesPerGaus", "[", 
    RowBox[{"v_", ",", "a_"}], "]"}], ":=", 
   RowBox[{"Module", "[", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"c", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "==", "1"}], ",", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{"v", ",", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"0", ",", 
                RowBox[{"Length", "[", "v", "]"}]}], "]"}]}], "]"}], "[", 
            RowBox[{"[", "j", "]"}], "]"}], ",", "0"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"2", "*", 
            RowBox[{"Length", "[", "v", "]"}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", 
           RowBox[{"2", "*", 
            RowBox[{"Length", "[", "v", "]"}]}]}], "}"}]}], "]"}]}], "}"}], 
     ",", " ", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "==", "1"}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"Join", "[", 
              RowBox[{"v", ",", 
               RowBox[{"ConstantArray", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"Length", "[", "v", "]"}]}], "]"}]}], "]"}], "[", 
             RowBox[{"[", "j", "]"}], "]"}], "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"j", "-", "1"}], ")"}], "!"}]}], ",", " ", 
           RowBox[{"(*", " ", 
            RowBox[{
            "To", " ", "assure", " ", "that", " ", "the", " ", "coefficients",
              " ", "correspond", " ", "coorectly", " ", "to", " ", "how", " ",
              "V", " ", "is", " ", "defined", " ", "in", " ", "these", " ", 
             "computations"}], "*)"}], 
           RowBox[{
            RowBox[{"1", "/", 
             RowBox[{"(", 
              RowBox[{"2", "*", "a"}], ")"}]}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"j", "+", "2"}], ">", 
                  RowBox[{"2", "*", 
                   RowBox[{"Length", "[", "v", "]"}]}]}], "||", 
                 RowBox[{
                  RowBox[{"i", "-", "1"}], "<=", "0"}]}], ",", "0", ",", 
                RowBox[{"c", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"i", "-", "1"}], ",", 
                   RowBox[{"j", "+", "2"}]}], "]"}], "]"}]}], "]"}], "+", 
              RowBox[{"Sum", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Binomial", "[", 
                  RowBox[{
                   RowBox[{"i", "-", "2"}], ",", 
                   RowBox[{"ip", "-", "1"}]}], "]"}], "*", 
                 RowBox[{"Binomial", "[", 
                  RowBox[{
                   RowBox[{"j", "-", "1"}], ",", 
                   RowBox[{"jp", "-", "1"}]}], "]"}], "*", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"jp", "+", "1"}], ">", 
                    RowBox[{"2", "*", 
                    RowBox[{"Length", "[", "v", "]"}]}]}], "||", 
                    RowBox[{"ip", "<=", "0"}]}], ",", "0", ",", 
                   RowBox[{"c", "[", 
                    RowBox[{"[", 
                    RowBox[{"ip", ",", 
                    RowBox[{"jp", "+", "1"}]}], "]"}], "]"}]}], "]"}], "*", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"i", "-", "ip"}], "<=", "0"}], "||", 
                    RowBox[{
                    RowBox[{"j", "-", "jp", "+", "2"}], ">", 
                    RowBox[{"2", "*", 
                    RowBox[{"Length", "[", "v", "]"}]}]}]}], ",", "0", ",", 
                   RowBox[{"c", "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{"i", "-", "ip"}], ",", 
                    RowBox[{"j", "-", "jp", "+", "2"}]}], "]"}], "]"}]}], 
                  "]"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"ip", ",", "1", ",", 
                  RowBox[{"i", "-", "1"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"jp", ",", "1", ",", "j"}], "}"}]}], "]"}]}], 
