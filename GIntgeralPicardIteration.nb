   RowBox[{"v_", ",", " ", "a_"}], "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Zy", ",", " ", "Zx"}], "}"}], ",", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{"Zy", " ", "=", " ", 
      RowBox[{"\[Integral]", 
       RowBox[{
        RowBox[{"\[DoubleStruckCapitalE]", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "a"}], "*", 
           RowBox[{
            SuperscriptBox["x", "2"], "/", "2"}]}], "+", " ", "v", "  ", "-", 
          " ", 
          RowBox[{"2", " ", "*", "\[Pi]", "*", "I", "*", "y", "*", "x"}]}], 
         "]"}], 
        RowBox[{"\[DifferentialD]", 
         RowBox[{"{", "x", "}"}]}]}]}]}], ";", " ", "\[IndentingNewLine]", 
     "\t", 
     RowBox[{"Zx", " ", "=", " ", 
      RowBox[{"\[Integral]", 
       RowBox[{
        RowBox[{"\[DoubleStruckCapitalE]", "[", 
         RowBox[{"2", " ", "*", "\[Pi]", "*", "I", "*", "y", "*", "x"}], 
         "]"}], "*", "Zy", "  ", 
        RowBox[{"\[DifferentialD]", 
         RowBox[{"{", "y", "}"}]}]}]}]}], ";", " ", "\[IndentingNewLine]", 
     "\t", "Zx"}]}], "]"}]}]], "Input",
