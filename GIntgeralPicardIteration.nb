   RowBox[{"CorrectGaussian", "[", "M4", "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9910572873374977`*^9, 3.9910573183799305`*^9}},
 CellLabel->"In[72]:=",ExpressionUUID->"1dbdc763-1536-014d-8011-69bd149a69f2"],

Cell[TextData[StyleBox["Examples from a Theory with a Source term ",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.9909468752132263`*^9, 3.99094688075177*^9}, {
  3.990948813939993*^9, 
  3.9909488169825497`*^9}},ExpressionUUID->"e7ca6022-07f8-6046-89ce-\
7b9e658be7ac"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CorrectLinearPerGaussian", "[", 
   RowBox[{"A_", ",", " ", "J_"}], "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"G", ",", " ", "I", ",", "n"}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{"n", "=", " ", 
      RowBox[{"Length", "[", "A", "]"}]}], ";", " ", 
     RowBox[{"G", "=", " ", 
      RowBox[{"Inverse", "[", "A", "]"}]}], ";", " ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"n", "==", "0"}], ",", 
       RowBox[{"I", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", "*", "Pi"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}]}], "*", 
         RowBox[{
          RowBox[{"\[DoubleStruckCapitalE]", "[", 
           RowBox[{
            RowBox[{"J", "^", "2"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", "*", "A"}], ")"}]}], "]"}], "/", 
          RowBox[{"Sqrt", "[", "A", "]"}]}]}]}], ",", 
       RowBox[{"I", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", "*", "Pi"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"n", "/", "2"}], ")"}]}], "*", 
         RowBox[{
          RowBox[{"\[DoubleStruckCapitalE]", "[", 
           RowBox[{"Collect", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"J", ".", "G", ".", "J"}], "/", "2"}], ",", " ", "J"}], 
            "]"}], "]"}], "/", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Det", "[", "A", "]"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"1", "/", "2"}], ")"}]}]}]}]}]}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9910564143849087`*^9, 3.9910564342249966`*^9}, {
   3.991056465322319*^9, 3.991056689550123*^9}, 3.9910567751125317`*^9, {
   3.991056809400875*^9, 3.991056829655672*^9}, {3.9910568722059517`*^9, 
   3.991056872985998*^9}, 3.9910571566500645`*^9, {3.9910571917829685`*^9, 
   3.9910572357382946`*^9}, {3.9910572664101944`*^9, 3.991057268624689*^9}},
 CellLabel->"In[67]:=",ExpressionUUID->"015c46fa-ea6c-454c-b42a-c3a8908a360f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Z1", "=", " ", 
   RowBox[{"\[Integral]", 
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalE]", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         FractionBox["1", "2"]}], "*", "m", "*", 
        RowBox[{
         SubscriptBox["\[Phi]", "1"], "^", "2"}]}], "+", " ", 
       RowBox[{"J1", "*", 
        SubscriptBox["\[Phi]", "1"]}]}], " ", "]"}], 
     RowBox[{"\[DifferentialD]", 
      RowBox[{"{", 
       SubscriptBox["\[Phi]", "1"], "}"}]}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FullSimplify", "[", "Z1", "]"}], "==", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"CorrectLinearPerGaussian", "[", 
    RowBox[{"m", ",", " ", "J1"}], "]"}], "]"}], 
  RowBox[{"(*", 
   RowBox[{
   "Need", " ", "FullSimplify", " ", "if", " ", "not", " ", "it", " ", 
    "returns", " ", "false"}], "*)"}]}]}], "Input",
