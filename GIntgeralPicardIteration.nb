Cell[BoxData[
 RowBox[{
  RowBox[{"SymmMatrix", "[", "n_", "]"}], " ", ":=", " ", 
  RowBox[{
   StyleBox["Module",
    Background->RGBColor[1, 1, 0]], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"A", ",", " ", "M"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"A", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"i", "<=", "j"}], ",", 
          RowBox[{"m", "[", 
           RowBox[{"i", ",", "j"}], "]"}], ",", "0"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", " ", 
     RowBox[{"M", "=", " ", 
      RowBox[{"A", " ", "+", " ", 
       RowBox[{"Transpose", "[", "A", "]"}], "-", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"Diagonal", "[", "A", "]"}], "]"}]}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9909445730584145`*^9, 3.9909446254659176`*^9}, {
  3.990944779636709*^9, 3.9909447917786407`*^9}, {3.9909450051318207`*^9, 
