Cell[BoxData[
 RowBox[{
  RowBox[{"CorrectGaussian", "[", "A_", "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"I", ",", "n"}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"Length", "[", "A", "]"}]}], ";", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"n", "==", "0"}], ",", " ", 
       RowBox[{"I", " ", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", "*", "Pi"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}]}], "/", " ", 
         RowBox[{"Sqrt", "[", "A", "]"}]}]}], ",", " ", 
       RowBox[{"I", " ", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", "*", "Pi"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"n", "/", "2"}], ")"}]}], "/", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"(", 
           RowBox[{"Det", "[", "A", "]"}], ")"}], "]"}]}]}]}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.990946059594654*^9, 3.990946064517803*^9}, {
