Cell[BoxData[{
 StyleBox[
  RowBox[{
   RowBox[{"Unprotect", "[", "Integrate", "]"}], ";"}],
  Background->RGBColor[1, 0.85, 0.85]], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   StyleBox[
    RowBox[{"\[Integral]", 
     RowBox[{"\[Omega]_.", 
      RowBox[{"\[DoubleStruckCapitalE]", "[", "L_", "]"}], 
      RowBox[{"\[DifferentialD]", 
       RowBox[{"(", "vs_List", ")"}]}]}]}],
    Background->RGBColor[1, 1, 0]], 
   StyleBox[":=",
    Background->RGBColor[1, 1, 0]], 
   RowBox[{
    StyleBox["Module",
     Background->RGBColor[1, 1, 0]], "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "n", ",", "L0", ",", "Q", ",", "\[CapitalDelta]", ",", "G", ",", "Z0", 
       ",", "Z", ",", "\[Lambda]", ",", "DZ", ",", "DDZ", ",", "FZ", ",", "a",
        ",", "b"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Length", "@", "vs"}]}], ";", " ", 
      StyleBox[
       RowBox[{"L0", "=", 
        RowBox[{"L", "/.", 
         RowBox[{"\[Epsilon]", "->", "0"}]}]}],
       Background->RGBColor[1, 0.85, 0.85]], 
      StyleBox[";",
       Background->RGBColor[1, 0.85, 0.85]], "\[IndentingNewLine]", 
      RowBox[{
       StyleBox["Q",
        Background->RGBColor[1, 1, 0]], 
       StyleBox["=",
        Background->RGBColor[1, 1, 0]], 
       RowBox[{
        StyleBox["Table",
         Background->RGBColor[1, 1, 0]], 
        StyleBox["[",
         Background->RGBColor[1, 1, 0]], 
        RowBox[{
         RowBox[{
          StyleBox[
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", 
              RowBox[{
               SubscriptBox["\[PartialD]", 
                RowBox[{
                 RowBox[{"vs", "[", 
                  RowBox[{"[", "a", "]"}], "]"}], ",", 
                 RowBox[{"vs", "[", 
                  RowBox[{"[", "b", "]"}], "]"}]}]], "L0"}]}], ")"}], "/.", 
            RowBox[{"Thread", "[", 
             RowBox[{"vs", "->", "0"}], "]"}]}],
           Background->RGBColor[1, 1, 0]], "/.", 
          StyleBox[
           RowBox[{
            SubscriptBox[
             RowBox[{"(", 
              RowBox[{"p", "|", "x"}], ")"}], "__"], "->", "0"}],
           Background->RGBColor[1, 0.85, 0.85]]}], ",", 
         RowBox[{"{", 
          RowBox[{"a", ",", "n"}], "}"}], ",", 
         RowBox[{"{", 
