      "\[IndentingNewLine]", 
      StyleBox[
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[CapitalDelta]", "=", 
            RowBox[{"Det", "[", "Q", "]"}]}], ")"}], "==", "0"}], ",", 
         RowBox[{
         "Return", "@", 
          "\"\<\!\(\*StyleBox[\"Degenerate\",FontColor->RGBColor[1, 0, \
0]]\)\!\(\*StyleBox[\" \",FontColor->RGBColor[1, 0, \
0]]\)\!\(\*StyleBox[\"Q\",FontColor->RGBColor[1, 0, \
0]]\)\!\(\*StyleBox[\"!\",FontColor->RGBColor[1, 0, 0]]\)\>\""}]}], "]"}],
       Background->RGBColor[1, 1, 0]], 
      StyleBox[";",
       Background->RGBColor[1, 1, 0]], "\[IndentingNewLine]", 
      RowBox[{"Z", "=", 
       RowBox[{"Z0", "=", 
        RowBox[{"CF", "@", 
         RowBox[{
          StyleBox["$\[Pi]",
           Background->RGBColor[1, 0.85, 0.85]], "[", 
          RowBox[{"L", "+", 
           RowBox[{
            RowBox[{"vs", ".", "Q", ".", "vs"}], "/", "2"}]}], "]"}]}]}]}], 
      ";", " ", 
      RowBox[{"G", "=", 
       RowBox[{"Inverse", "[", "Q", "]"}]}], ";", "\[IndentingNewLine]", 
      StyleBox[
       RowBox[{"FixedPoint", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"DZ", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{
                SubscriptBox["\[PartialD]", "v"], "Z"}], ",", 
               RowBox[{"{", 
