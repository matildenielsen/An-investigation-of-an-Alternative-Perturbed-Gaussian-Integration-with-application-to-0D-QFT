              RowBox[{
               RowBox[{
                SubscriptBox["\[PartialD]", "u"], "DZ"}], ",", 
               RowBox[{"{", 
                RowBox[{"u", ",", "vs"}], "}"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"FZ", "=", 
             RowBox[{
              RowBox[{"Sum", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"G", "[", 
                  RowBox[{"[", 
                   RowBox[{"a", ",", "b"}], "]"}], "]"}], 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"DDZ", "[", 
                    RowBox[{"[", 
                    RowBox[{"a", ",", "b"}], "]"}], "]"}], "+", 
                   RowBox[{
                    RowBox[{"DZ", "[", 
                    RowBox[{"[", "a", "]"}], "]"}], 
